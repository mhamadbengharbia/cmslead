<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Admin</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(120, 119, 255, 0.16), transparent 30%),
                radial-gradient(circle at bottom right, rgba(120, 220, 255, 0.14), transparent 28%),
                #f5f7ff;
            color: #0f172a;
        }

        .layout {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 270px;
            background: #081735;
            color: white;
            padding: 28px 20px;
            box-shadow: 8px 0 30px rgba(15, 23, 42, 0.08);
        }

        .sidebar h2 {
            margin: 0 0 30px 0;
            font-size: 34px;
            line-height: 1;
        }

        .sidebar .subtitle {
            color: #93c5fd;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .sidebar a {
            display: block;
            color: #ffffff;
            text-decoration: none;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 10px;
            transition: background 0.2s ease;
        }

        .sidebar a:hover {
            background: rgba(255, 255, 255, 0.08);
        }

        .main {
            flex: 1;
            padding: 32px;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .page-title {
            margin: 0;
            font-size: 44px;
            font-weight: 800;
            color: #0b132b;
        }

        .page-subtitle {
            margin-top: 8px;
            color: #64748b;
            font-size: 16px;
        }

        .logout-btn {
            display: inline-block;
            padding: 14px 18px;
            border-radius: 14px;
            background: #ef4444;
            color: white;
            text-decoration: none;
            font-weight: 700;
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(8px);
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 26px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
        }

        .stat-label {
            color: #64748b;
            font-size: 15px;
            margin-bottom: 12px;
        }

        .stat-value {
            font-size: 42px;
            font-weight: 800;
            color: #0b132b;
            margin: 0;
        }

        .actions-card {
            background: rgba(255, 255, 255, 0.82);
            backdrop-filter: blur(8px);
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08);
            max-width: 900px;
        }

        .actions-card h2 {
            margin: 0 0 10px 0;
            font-size: 28px;
            color: #0b132b;
        }

        .actions-card p {
            margin: 0 0 22px 0;
            color: #64748b;
        }

        .actions-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 16px;
        }

        .action-link {
            display: block;
            text-decoration: none;
            background: linear-gradient(135deg, #ffffff, #f8fbff);
            border: 1px solid #dbeafe;
            border-radius: 18px;
            padding: 20px;
            color: #0f172a;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

        .action-link:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 26px rgba(37, 99, 235, 0.10);
        }

        .action-title {
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px;
            color: #1d4ed8;
        }

        .action-text {
            color: #64748b;
            font-size: 14px;
            line-height: 1.5;
        }

        @media (max-width: 900px) {
            .layout {
                flex-direction: column;
            }

            .sidebar {
                width: 100%;
            }

            .topbar {
                flex-direction: column;
                align-items: flex-start;
                gap: 14px;
            }

            .page-title {
                font-size: 34px;
            }
        }
    </style>
</head>
<body>
    <div class="layout">
        <aside class="sidebar">
            <h2>Admin</h2>
            <div class="subtitle">Mini CMS acquisition</div>

            <a href="{{ path('admin_dashboard') }}">Dashboard</a>
            <a href="{{ path('admin_partner_index') }}">Gérer les partners</a>
            <a href="{{ path('admin_lead_index') }}">Gérer les leads</a>
            <a href="{{ path('admin_landing_page_index') }}">Gérer les landing pages</a>
            <a href="{{ path('app_logout') }}">Logout</a>
        </aside>

        <main class="main">
            <div class="topbar">
                <div>
                    <h1 class="page-title">Dashboard Admin</h1>
                    <div class="page-subtitle">
                        Vue globale de la plateforme et accès rapide aux modules.
                    </div>
                </div>

                <a class="logout-btn" href="{{ path('app_logout') }}">Logout</a>
            </div>

            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Partners</div>
                    <p class="stat-value">{{ partnerCount }}</p>
                </div>

                <div class="stat-card">
                    <div class="stat-label">Landing pages</div>
                    <p class="stat-value">{{ landingPageCount }}</p>
                </div>

                <div class="stat-card">
                    <div class="stat-label">Leads</div>
                    <p class="stat-value">{{ leadCount }}</p>
                </div>
            </div>

            <div class="actions-card">
                <h2>Accès rapides</h2>
                <p>Gère les partenaires, consulte les leads et pilote les landing pages depuis un seul endroit.</p>

                <div class="actions-grid">
                    <a class="action-link" href="{{ path('admin_partner_index') }}">
                        <div class="action-title">Partners</div>
                        <div class="action-text">Créer, modifier, activer ou supprimer les comptes partenaires.</div>
                    </a>

                    <a class="action-link" href="{{ path('admin_lead_index') }}">
                        <div class="action-title">Leads</div>
                        <div class="action-text">Voir tous les leads générés sur la plateforme.</div>
                    </a>

                    <a class="action-link" href="{{ path('admin_landing_page_index') }}">
                        <div class="action-title">Landing pages</div>
                        <div class="action-text">Superviser les pages créées et leurs templates.</div>
                    </a>
                </div>
            </div>
        </main>
    </div>
</body>
</html>