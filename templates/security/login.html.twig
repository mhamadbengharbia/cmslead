<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion</title>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background:
                radial-gradient(circle at top left, rgba(120, 119, 255, 0.18), transparent 35%),
                radial-gradient(circle at bottom right, rgba(120, 220, 255, 0.18), transparent 30%),
                #f5f7ff;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            color: #0f172a;
        }

        .login-card {
            width: 100%;
            max-width: 440px;
            background: rgba(255, 255, 255, 0.88);
            backdrop-filter: blur(10px);
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 36px;
            box-shadow: 0 20px 50px rgba(15, 23, 42, 0.10);
        }

        .badge {
            display: inline-block;
            margin-bottom: 18px;
            padding: 10px 16px;
            border-radius: 999px;
            background: #e9e7ff;
            color: #4f46e5;
            font-weight: 700;
            font-size: 14px;
        }

        .login-title {
            margin: 0 0 10px 0;
            font-size: 42px;
            line-height: 1.05;
            font-weight: 800;
            color: #0b132b;
        }

        .login-subtitle {
            margin: 0 0 28px 0;
            color: #64748b;
            font-size: 16px;
            line-height: 1.5;
        }

        .alert-error {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px 14px;
            border-radius: 12px;
            margin-bottom: 18px;
            font-size: 14px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 700;
            color: #0f172a;
        }

        input[type="email"],
        input[type="password"] {
            width: 100%;
            padding: 14px 15px;
            border: 1px solid #cbd5e1;
            border-radius: 14px;
            font-size: 15px;
            background: #ffffff;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }

        input[type="email"]:focus,
        input[type="password"]:focus {
            outline: none;
            border-color: #4f46e5;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.12);
        }

        .login-btn {
            width: 100%;
            border: none;
            background: linear-gradient(90deg, #4f46e5, #2563eb);
            color: #ffffff;
            padding: 15px;
            border-radius: 14px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            box-shadow: 0 12px 24px rgba(79, 70, 229, 0.20);
        }

        .login-btn:hover {
            transform: translateY(-1px);
        }

        .login-footer {
            margin-top: 18px;
            text-align: center;
            color: #64748b;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="badge">Plateforme d’acquisition</div>

        <h1 class="login-title">Connexion</h1>
        <p class="login-subtitle">
            Connecte-toi à ton espace admin ou partner.
        </p>

        {% if error %}
            <div class="alert-error">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="username">Email</label>
                <input
                    type="email"
                    id="username"
                    name="_username"
                    value="{{ last_username }}"
                    required
                    autofocus
                >
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input
                    type="password"
                    id="password"
                    name="_password"
                    required
                >
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button class="login-btn" type="submit">
                Se connecter
            </button>
        </form>

        <div class="login-footer">
            Admin • Partner
        </div>
    </div>
</body>
</html>