<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Modifier landing page</title>
</head>
<body>
    <div style="display:flex; justify-content:space-between; align-items:center;">
        <h1>Modifier {{ landingPage.name }}</h1>
        <a href="{{ path('app_logout') }}">Logout</a>
    </div>

    <p>
        <a href="{{ path('partner_dashboard') }}">Dashboard</a> |
        <a href="{{ path('partner_landing_page_index') }}">Mes landing pages</a>
    </p>

    {% for message in app.flashes('success') %}
        <div style="background:#dcfce7; color:#166534; padding:10px; margin-bottom:15px;">
            {{ message }}
        </div>
    {% endfor %}

    {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.slug) }}
        {{ form_row(form.title) }}
        {{ form_row(form.subtitle) }}
        {{ form_row(form.ctaText) }}
        {{ form_row(form.formTitle) }}
        {{ form_row(form.successMessage) }}
        {{ form_row(form.primaryColor) }}
        {{ form_row(form.secondaryColor) }}
        {{ form_row(form.buttonColor) }}
        {{ form_row(form.landingTemplate) }}
        {{ form_row(form.isActive) }}
        {{ form_row(form.save) }}
    {{ form_end(form) }}

    <hr>

    <p>
        URL publique :
        <a href="/{{ partner.slug }}/{{ landingPage.slug }}" target="_blank">
            /{{ partner.slug }}/{{ landingPage.slug }}
        </a>
    </p>
</body>
</html>